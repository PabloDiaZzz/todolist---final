  "main": "index.js",
  "scripts": {
    "generate-types": "npm --prefix frontend run generate-types",

    "frontend:install": "npm --prefix frontend install",
    "frontend:build": "npm --prefix frontend run build",

    "backend:run": "mvnw.cmd spring-boot:run -Dspring-boot.run.jvmArguments=\"-Dserver.port=8080\" -Dfrontend.build.skip=true",

    "dev": "concurrently --kill-others \"npm run backend:run\" \"npm --prefix frontend run dev\""
